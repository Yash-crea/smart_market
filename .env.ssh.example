# SSH Configuration for Grocery Store Deployment
# Copy this file to .env in your project root and update with your server details

# Production Server Configuration
PROD_HOST=your_production_server.com
PROD_USER=ubuntu
PROD_PORT=22
PROD_KEY_FILE=~/.ssh/grocery_prod_key

# Staging Server Configuration  
STAGING_HOST=your_staging_server.com
STAGING_USER=ubuntu
STAGING_PORT=22
STAGING_KEY_FILE=~/.ssh/grocery_staging_key

# Database Server Configuration
DB_HOST=your_database_server.com
DB_USER=ubuntu
DB_PORT=22
DB_KEY_FILE=~/.ssh/grocery_db_key

# Redis Cache Server Configuration
CACHE_HOST=your_redis_server.com
CACHE_USER=ubuntu
CACHE_PORT=22
CACHE_KEY_FILE=~/.ssh/grocery_cache_key

# SSH Security Settings
SSH_TIMEOUT=30
SSH_MAX_RETRIES=3
SSH_USE_SYSTEM_HOST_KEYS=True
SSH_AUTO_ADD_UNKNOWN_HOSTS=False

# Deployment Settings
REMOTE_PROJECT_PATH=/var/www/grocery_store
BACKUP_PATH=/home/ubuntu/backups

# Monitoring Settings
MONITOR_INTERVAL=300
ENABLE_SSH_ALERTS=True
SSH_LOG_LEVEL=INFO

# Example server configurations for different environments:

# For AWS EC2:
# PROD_HOST=ec2-xxx-xxx-xxx-xxx.compute-1.amazonaws.com
# PROD_USER=ec2-user
# PROD_KEY_FILE=~/.ssh/grocery-store-aws.pem

# For DigitalOcean:
# PROD_HOST=xxx.xxx.xxx.xxx
# PROD_USER=root
# PROD_KEY_FILE=~/.ssh/grocery-store-do

# For Google Cloud:
# PROD_HOST=xxx.xxx.xxx.xxx  
# PROD_USER=grocery
# PROD_KEY_FILE=~/.ssh/grocery-store-gcp

# For local development/testing:
# PROD_HOST=localhost
# PROD_USER=vagrant
# PROD_PORT=2222
# PROD_KEY_FILE=~/.ssh/vagrant_key